# ---- LLM provider ----
# Provider-abstracted; Google Gemini (free tier).
GOOGLE_API_KEY=your-gemini-key-here
LLM_MODEL=gemini-3-flash-preview
LLM_TEMPERATURE=0

# ---- PostgreSQL (checkpointer + audit + pgvector) ----
POSTGRES_USER=resolution
POSTGRES_PASSWORD=resolution
POSTGRES_DB=resolution_desk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full DSN used by the app / checkpointer
DATABASE_URL=postgresql://resolution:resolution@localhost:5432/resolution_desk?sslmode=disable

# ---- MCP tool server ----
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8100

# ---- Business policy (deterministic governance thresholds) ----
# Refunds strictly greater than this amount require human approval.
REFUND_AUTO_APPROVE_LIMIT=50.0

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
